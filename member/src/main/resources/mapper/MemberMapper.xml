<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace = Mapper 인터페이스 전체 경로 (정확히 일치해야 함!) -->
<mapper namespace="com.example.member.mapper.MemberMapper">
    <!-- ────────────────────────────────────────── -->
    <!-- ResultMap: 컬럼명 ↔ 필드명 매핑 (필요 시 사용) -->
    <!-- ─────────────────────────────────────────── -->
    <resultMap id="memberResultMap" type="Member">
        <id     property="id"   column="id"/>
        <result property="name" column="name"/>
        <result property="name" column="age"/>
        <result property="name" column="email"/>
        <result property="name" column="phone"/>
        <result property="name" column="address"/>
    </resultMap>
    <!-- ────────────────────────────────────────────────── -->
    <!-- 공통 SQL 조각 (재사용) -->
    <!-- ────────────────────────────────────────────────── -->
    <sql id="selectMember">
        select id, name, age, email, phone, address
          from member
    </sql>
    <!-- ─── 전체 조회 ─────────────────────────────────── -->
    <select id="findAll" resultType="com.example.member.entity.Member">
        select id, name, age, email, phone, address
          from member
         order by id desc
    </select>
    <!-- ─── 이름 검색 ───────────────────────────────────
    <select id="findByNameContaining" resultType="Member">
        <include refid="selectMember"/>
        where name like concat('%', #{keyword}, '%')
        order by id desc
    </select>  -->
    <select id="findByNameContaining" resultType="Member">
        select id, name, age, email, phone, address
        from member
        where name like concat('%', #{keyword}, '%')
    </select>
    <!-- ─── 단건 조회 (PK) ────────────────────────────── -->
    <select id="findById" resultType="Member">
        select id, name, age, email, phone, address
          from member
         where id = #{id}
    </select>
    <!-- ─── 이메일 조회 (중복 체크) ─────────────────────
    <select id="findByEmail" resultType="Member">
        <include refid="selectMember"/>
        WHERE email = #{email}
    </select> -->
    <select id="findByEmail" resultType="Member">
        select id, name, age, email, phone, address
          from member
         where email = #{email}
    </select>
    <!-- ─── 회원 수정 ─────────────────────────────────── -->
    <update id="updateMember" parameterType="Member">
        update member
          set name = #{name},
              age = #{age},
              email = #{email},
              phone = #{phone},
              address = #{address}
        where id = #{id}
    </update>
    <!-- ─── 회원 삭제 ─────────────────────────────────── -->
    <delete id="deleteMember">
        delete
          from member
         where id = #{id}
    </delete>
    <!-- ─── 회원 등록 ─────────────────────────────────── -->
    <!-- useGeneratedKeys: auto increment 키 자동 반환 -->
    <insert id="insertMember" parameterType="Member"
        useGeneratedKeys="true" keyProperty="id">
        insert into member(name, email, age,  phone, address)
               values(#{name}, #{email}, #{age}, #{phone}, #{address})
    </insert>
</mapper>